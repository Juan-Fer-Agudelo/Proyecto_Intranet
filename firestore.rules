rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: announcements
    // Fields: title (string), content (string), image (string?), active (bool), createdAt (timestamp)
    //
    // Collection: videos
    // Fields: title (string), url (string), createdAt (timestamp)
    //
    // Collection: partyPhotos
    // Fields: url (string), createdAt (timestamp)
    //
    // Collection: settings
    // Document: global
    // Fields: visitInfo (string), heroBg (string), rhVideo (string)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "juanferagudelo475@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidAnnouncement(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 2000 &&
             data.active is bool &&
             (!('image' in data) || (data.image is string && data.image.size() < 2000000)); // Limit image size if base64
    }

    function isValidVideo(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.size() > 0;
    }

    function isValidPhoto(data) {
      return data.url is string && data.url.size() > 0 && data.url.size() < 2000000;
    }

    function isValidSettings(data) {
      return (!('visitInfo' in data) || (data.visitInfo is string && data.visitInfo.size() < 500)) &&
             (!('heroBg' in data) || (data.heroBg is string && data.heroBg.size() < 2000000)) &&
             (!('rhVideo' in data) || (data.rhVideo is string && data.rhVideo.size() < 2000000));
    }

    // Rules
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidAnnouncement(request.resource.data);
    }

    match /videos/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidVideo(request.resource.data);
    }

    match /partyPhotos/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidPhoto(request.resource.data);
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
